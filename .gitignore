# ── Secrets / environment ─────────────────────────────────────
.env
*.env
!.env.example          # keep the template — it has no real keys

# ── Database (live trading data — never commit) ───────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── Python runtime ────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
*.pyz
venv/
.venv/
env/
.env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
nohup.out             # VPS process output when run with nohup

# ── Backtest generated output (not source) ────────────────────
backtest/data/        # historical OHLCV JSON files — too large for git
backtest/results.json # generated by backtest runs
backtest/output/      # any output directories
tests/data/           # test fixture data files
tests/fixtures/

# ── Historical price data files ───────────────────────────────
data/*.json           # any downloaded price history
data/*.csv
*.csv                 # exported trade data

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── VPS / deployment artifacts ────────────────────────────────
*.pid                 # process ID files
*.pid.lock

# ── Windows batch outputs ─────────────────────────────────────
# ops/upload_to_vps.bat is tracked (useful template)
# but any generated output files are not

# ── n8n ───────────────────────────────────────────────────────
# n8n/confluence_workflow.json IS tracked — it's config, not data

# ── Telegram / notification state ────────────────────────────
notifications/*.tmp

# ── Temporary / scratch files ────────────────────────────────
scratch/
tmp/
*.tmp
*.bak
*.orig

# ── WAL / SHM (SQLite runtime files) ────────────────────────
*.db-wal
*.db-shm

# ── Windows batch scripts (machine-specific paths) ──────────
start_bot.bat

# ── Verification scripts (dev tools, not production) ─────────
verify_*.py
