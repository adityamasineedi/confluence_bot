# confluence_bot — environment variable template
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# ── Coinglass ────────────────────────────────────────────────────────────────
COINGLASS_API_KEY=your_coinglass_api_key_here

# ── CryptoQuant ──────────────────────────────────────────────────────────────
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key_here

# ── Deribit ──────────────────────────────────────────────────────────────────
DERIBIT_CLIENT_ID=your_deribit_client_id_here
DERIBIT_CLIENT_SECRET=your_deribit_client_secret_here

# ── Coinbase Advanced Trade ───────────────────────────────────────────────────
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ── n8n / Telegram ───────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/confluence-signal
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=confluence_bot.db

# ── Metrics API ──────────────────────────────────────────────────────────────
METRICS_URL=http://localhost:8000/health
